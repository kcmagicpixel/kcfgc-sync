{
  "name": "@emily-curry/fgc-sync-start-gg",
  "description": "CLI application for loading data from start.gg",
  "version": "0.0.0",
  "private": true,
  "author": "Emily Curry <emily@curry.sh>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "format": "prettier --write src",
    "exec:t": "node -r dotenv/config dist/index.js tournaments magic-pixel-weekly-120 > ./out/tournaments.json",
    "exec:h": "node -r dotenv/config dist/index.js hubs magic-pixel > ./out/hubs.json",
    "clean": "rm -rf dist",
    "purge": "rm -rf node_modules"
  },
  "dependencies": {
    "@emily-curry/fgc-sync-common": "workspace:*",
    "argparse": "^2.0.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/argparse": "^2.0.10",
    "@types/node": "^24.0.0",
    "dotenv": "^16.0.3"
  }
}
