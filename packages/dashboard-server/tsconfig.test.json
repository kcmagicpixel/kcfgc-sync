{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "rootDir": ".",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ESNext"],
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "resolvePackageJsonImports": true,
    "paths": {
      "#config": ["./src/config.ts"],
      "#container": ["./src/container.ts"],
      "#log": ["./src/log.ts"],
      "#modules/*": ["./src/modules/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "include": ["tests", "src"]
}
