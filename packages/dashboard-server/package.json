{
  "name": "@emily-curry/fgc-sync-dashboard-server",
  "version": "0.0.0",
  "private": true,
  "author": "Emily Curry <emily@curry.sh>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "imports": {
    "#config": "./dist/config.js",
    "#container": "./dist/container.js",
    "#log": "./dist/log.js",
    "#utils/*": "./dist/utils/*"
  },
  "scripts": {
    "watch": "tsx watch --exclude=\"../dashboard-web/**/*\" --clear-screen=false -r dotenv/config ./src/index.ts",
    "build": "tsc -p tsconfig.app.json",
    "format": "prettier --write src tests",
    "clean": "rm -rf dist",
    "purge": "rm -rf node_modules",
    "test": "vitest"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^9.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.10.1",
    "dotenv": "^16.0.3",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
