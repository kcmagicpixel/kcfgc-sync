{
  "name": "@emily-curry/fgc-sync-root",
  "version": "0.0.0",
  "private": true,
  "author": "Emily Curry <emily@curry.sh>",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "watch": "pnpm -r --parallel --stream run watch",
    "format": "pnpm -r --parallel run format",
    "lint": "eslint",
    "clean": "pnpm -r --parallel run clean",
    "purge": "pnpm -r --parallel run purge && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
